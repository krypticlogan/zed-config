// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cursor_shape": "block",
  "relative_line_numbers": "disabled",
  "soft_wrap": "prefer_line",
  "terminal": {
    "dock": "right",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "project_panel": {
    "dock": "left",
  },
  "proxy": "",
  "session": {
    "trust_all_worktrees": true,
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Tokyo Night Light",
    "dark": "Rosé Pine",
  },
  "lsp": {
    "zls": {
      "initialization_options": {
        "enable_inlay_hints": true,
        "inlay_hints_show_parameter_name": true,
        "inlay_hints_show_variable_type_hints": true,
        "inlay_hints_show_struct_literal_field_type": true,
      },
    },
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
  },
  "theme_overrides": {
    "Rosé Pine": {
      "background.appearance": "blurred",
      "background": "#00000030",
      "editor.background": "#00000010",
      "editor.gutter.background": "#00000030",
      "editor.active_line.background": "#66666680",
      "panel.background": "#00000030",
      "tab_bar.background": "#00000030",
      "title_bar.background": "#00000030",
      "status_bar.background": "#00000030",
      "toolbar.background": "#00000030",
      "tab.active_background": "#28282820",
      "tab.inactive_background": "#00000000",
      "terminal.background": "#00000030",
    },
  },
}
